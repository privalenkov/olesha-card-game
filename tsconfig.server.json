{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist-server"
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "src/game/config.ts",
    "src/game/types.ts",
    "src/game/rarityBalance.ts"
  ]
}
